<!-- assistant.board — 基础 AI 助手组件示例 -->

<template>
  You are {{ role }}.

  <if :condition="user !== null">
  User profile: {{ user.name }}, preferences: {{ user.prefs }}
  </if>

  Current task: {{ task }}

  <if :condition="recentHistory.length > 0">
  Recent context:
  <each :items="recentHistory" :as="item">
  - {{ item }}
  </each>
  </if>
</template>

<script>
// 响应式状态（自动更新模板）
let role = 'a helpful assistant'
let task = ''
let user = null
let recentHistory = []

on('mount', () => {
  // 从 session 读取持久化状态
  role = inject('agent_role') ?? 'a helpful assistant'
  user = inject('user') ?? null
})

on('update', (input) => {
  // input 格式由使用方决定
  if (input?.type === 'message') {
    task = input.content
  } else if (input?.type === 'tool_response') {
    // 精细控制数据生命周期
    session('last_tool_result', input.result)   // 整个会话保留
    turn(input.raw_data)                          // 只这轮用
    history(input.summary)                        // 进历史
    drop(input.debug_info)                        // 直接丢弃

    // 响应式更新
    task = input.next_task ?? task
    recentHistory = [...recentHistory.slice(-3), input.summary]
  } else if (input?.type === 'llm_response') {
    if (input.finish_reason === 'stop') {
      history(input.content)
    }
  }
})
</script>

<config>
model: gpt-4o
max_tokens: 4000
temperature: 0.7
</config>
