{
  "id": "promptu",
  "name": "Promptu Runtime",
  "description": "Promptu (.ptu) language runtime for OpenClaw — gives AI full control over LLM request lifecycle",
  "version": "0.1.0",
  "openclaw": {
    "extensions": ["./src/index.ts"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "projectPath": {
        "type": "string",
        "description": "Path to the .ptu project directory (contains main.ptu or promptu.config.js)"
      },
      "entry": {
        "type": "string",
        "default": "main.ptu",
        "description": "Entry .ptu file relative to projectPath"
      },
      "enabled": {
        "type": "boolean",
        "default": true
      }
    },
    "required": ["projectPath"]
  },
  "uiHints": {
    "projectPath": { "label": "Project Path", "placeholder": "~/my-agent" },
    "entry": { "label": "Entry File", "placeholder": "main.ptu" }
  }
}
